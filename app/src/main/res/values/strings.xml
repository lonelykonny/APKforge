    <!-- Theme AppCompat (requis par AppCompatActivity, qui applique les
         per-app locales). Les couleurs UI viennent dynamiquement de Compose ;
         ce theme ne fixe que les bases (splash, barres transparentes). -->
    <style name="Theme.Forge" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Fond de fenetre (jour/nuit) montre pendant la recreation d'activite
             au changement de langue : remplace le flash noir par un fond neutre. -->
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

